# Get these from https://my.telegram.org  →  API development tools
API_ID=12345678
API_HASH=your_api_hash_here

# Command prefix (default: .)
CMD_PREFIX=.

# Required for Koyeb / cloud: generate with  python generate_session.py
# SESSION_STRING=

# Delay between batch saves (seconds) — raise if FloodWait / ban risk
WAITING_TIME=3

# Optional: persistent data folder (use a Koyeb volume mount, e.g. /data)
# DATA_DIR=/data

# Optional: Turso free remote SQLite (survives Koyeb rebuilds — no volume needed)
# Create DB at https://turso.tech → copy URL + token
# TURSO_DATABASE_URL=libsql://your-db-name-user.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# Optional: OCR + better translate (OpenRouter free works)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openrouter/free

# Organizer: days without activity before .org inactive / clean
ORG_INACTIVE_DAYS=30
